# SegOps — copy to .env.local (gitignored). Do not commit real keys.

# Browser-exposed (NEXT_PUBLIC_): the API base URL and the public key.
# Point API_URL at your SegOps stack — local now, the hosted URL once DNS is live.
NEXT_PUBLIC_SEGOPS_API_URL=http://localhost:8000
NEXT_PUBLIC_SEGOPS_PUBLIC_KEY=pk_xxx

# Server-only: the public key's HMAC secret (shown once at key creation).
# Used by the /api/segops/sign route to sign the logged-in user's id.
# NEVER prefix this with NEXT_PUBLIC_.
SEGOPS_HMAC_SECRET=replace-with-your-hmac-secret
